# Copy to config.env and fill in your values

# SMTP (outgoing – ticket confirmations, public links)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=itsm2714@gmail.com
SMTP_PASSWORD=your-app-password

# Public ticket link base URL (for confirmation emails, welcome emails, support links)
# Used in first-time user welcome email: {base}/{product}?m=&u=&e={email}
PUBLIC_BASE_URL=http://localhost:3000

# Incoming email (customer replies stored as messages - no ticket creation)
# Uses same credentials as SMTP by default. Set IMAP_INCOMING_ENABLED=false to disable.
IMAP_INCOMING_ENABLED=true
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Note: Ticket creation from email is disabled. Tickets are created only via the user support URL.

# Business Dashboard password-only access (no CEO/Manager login required)
# Default: vdata1234. Set to customize.
# BUSINESS_DASHBOARD_PASSWORD=your-secure-password
